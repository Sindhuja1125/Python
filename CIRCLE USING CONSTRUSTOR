class CIRCLES:
    def __init__(self):
        x=int(input("enter the radius:"))
        self.radius=x
    def display(self):
        print("The Area is: ", 3.14*self.radius**2)
    

a=int(input("Enter no.of circles: "))
circles=[]
for i in range(a):
    c=CIRCLES()
    circles.append(c)
    c.display()
